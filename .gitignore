.env.local
.env.production

# Файлы Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Логи
*.log
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Файлы тестов
.pytest_cache/
.tox/
.coverage
htmlcov/

# Распространяемые файлы
dist/
build/
*.egg-info/
